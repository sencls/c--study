            "options": {
                "cwd": "${fileDirname}",
                "env": {
                    "TMP": "C:\\temp",
                    "TEMP": "C:\\temp"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "编译器: C:\\Program Files\\mingw64\\bin\\g++.exe"
        }
    ],
    "version": "2.0.0"
