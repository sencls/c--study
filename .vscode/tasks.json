{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "C:\\Program Files\\mingw64\\bin\\g++.exe",
            "args": [
                "-std=c++20",
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "${workspaceFolder}/third_party/src/json_reader.cpp",
                "${workspaceFolder}/third_party/src/json_value.cpp",
                "${workspaceFolder}/third_party/src/json_writer.cpp",
                "-I${workspaceFolder}/third_party",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-lws2_32",
                "-lmswsock"
